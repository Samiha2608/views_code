<h1>Leave a Comment</h1>

<%= form_with url: "/comments", local: true do %>
  <div>
    <%= label_tag :name %><br>
    <%= text_field_tag :name %>
  </div>

  <div>
    <%= label_tag :comment %><br>
    <%= text_area_tag :comment %>
  </div>

  <div>
    <%= submit_tag "Post Comment" %>
  </div>
<% end %>
